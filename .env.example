# Frontend Environment Variables (apps/web/.env)

# PocketBase Configuration
# URL of your PocketBase server
# For local development: http://localhost:8090
# For production: https://your-pocketbase-domain.com
VITE_POCKETBASE_URL=http://localhost:8090

# Stripe Configuration
# Get your Stripe public key from: https://dashboard.stripe.com/apikeys
# This key is safe to expose in frontend code
# Test key starts with: pk_test_
# Live key starts with: pk_live_
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# API Server Configuration
# URL of your Express.js backend API server
# For local development: http://localhost:3001
# For production: https://your-api-domain.com
VITE_API_SERVER_URL=http://localhost:3001

# Environment Mode
# Set to 'development' for local development
# Set to 'production' for production builds
NODE_ENV=development

# Backend Environment Variables (apps/api/.env)

# Stripe Secret Key Configuration
# Get your Stripe secret key from: https://dashboard.stripe.com/apikeys
# KEEP THIS SECRET - Never commit to version control
# Test key starts with: sk_test_
# Live key starts with: sk_live_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Environment Mode
# Set to 'development' for local development
# Set to 'production' for production builds
NODE_ENV=development

# Optional: Gemini API Key
# For AI-powered features (if implemented)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: PocketBase Admin Email
# Email of the PocketBase admin account
POCKETBASE_ADMIN_EMAIL=admin@ecommerce.com

# Optional: PocketBase Admin Password
# Password for the PocketBase admin account
POCKETBASE_ADMIN_PASSWORD=admin123